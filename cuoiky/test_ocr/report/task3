predict() (dòng 327-341) — Unified API
def predict(self, image):
    img_np = process_input(image)  # Tiền xử lý
    if self.seq_modeling == "transformer":
        return self.predict_transformer(img_np)
    else:
        return self.predict_seq2seq(img_np)


